# Neon Postgres environment template.
# Replace all placeholder values with your own project credentials.
DATABASE_NEON_PROJECT_ID="your-neon-project-id"
DATABASE_PGDATABASE="neondb"
DATABASE_PGHOST="your-project-pooler.region.aws.neon.tech"
DATABASE_PGHOST_UNPOOLED="your-project.region.aws.neon.tech"
DATABASE_PGPASSWORD="your-neon-password"
DATABASE_PGUSER="your-neon-user"

DATABASE_POSTGRES_DATABASE="neondb"
DATABASE_POSTGRES_HOST="your-project-pooler.region.aws.neon.tech"
DATABASE_POSTGRES_PASSWORD="your-neon-password"
DATABASE_POSTGRES_PRISMA_URL="postgresql://your-neon-user:your-neon-password@your-project-pooler.region.aws.neon.tech/neondb?channel_binding=require&connect_timeout=15&sslmode=require"
DATABASE_POSTGRES_URL="postgresql://your-neon-user:your-neon-password@your-project-pooler.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
DATABASE_POSTGRES_URL_NON_POOLING="postgresql://your-neon-user:your-neon-password@your-project.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
DATABASE_POSTGRES_URL_NO_SSL="postgresql://your-neon-user:your-neon-password@your-project-pooler.region.aws.neon.tech/neondb"
DATABASE_POSTGRES_USER="your-neon-user"

DATABASE_URL="postgresql://your-neon-user:your-neon-password@your-project-pooler.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://your-neon-user:your-neon-password@your-project.region.aws.neon.tech/neondb?sslmode=require"

# Optional and auto-managed by Vercel CLI in local workflows.
VERCEL_OIDC_TOKEN="<REDACTED>"
